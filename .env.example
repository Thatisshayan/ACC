# ACC v2 .env.example — copy to .env and fill in values
# Variables marked [REQUIRED_PROD] will cause the server to refuse to start in production if missing.
# Variables marked [WARN_PROD] are logged as warnings in production but do not block startup.

# ── Core ──────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Auth / API Keys ───────────────────────────────────────────────────────────
ACC_OPERATOR_API_KEY=your_long_random_operator_key   # [REQUIRED_PROD] Bearer token for API access
ACC_ADMIN_API_KEY=your_long_random_admin_key          # optional second-tier key
TASKBUS_API_KEY=your_taskbus_service_key              # service-level key for internal callers
INTERNAL_SERVICE_TOKEN=your_internal_shared_secret    # shared secret for server → taskbus calls
VITE_TASKBUS_API_KEY=same_as_taskbus_api_key          # injected into the Vite/React build

# ── Security ──────────────────────────────────────────────────────────────────
ACC_VAULT_MASTER_KEY=strong_random_32+_char_password  # [REQUIRED_PROD] AES-256-GCM master key for vault
ACC_APPROVAL_HMAC_SECRET=strong_hmac_secret           # HMAC signing key for approval records

# ── Database (Supabase) ───────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co         # [REQUIRED_PROD]
SUPABASE_ANON_KEY=eyJ...                              # public anon key (safe for browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...                      # [REQUIRED_PROD] server-only — never expose to browser

# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token                     # [WARN_PROD]
TELEGRAM_WEBHOOK_SECRET=random_secret_for_webhook     # [REQUIRED_PROD] set same value in setWebhook call
SHAYAN_TELEGRAM_CHAT_ID=your_user_id
SAYAN_TELEGRAM_CHAT_ID=your_user_id                   # legacy alias — same value as above

# ── AI Providers ──────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...                               # [WARN_PROD] primary AI provider
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=
GROK_API_KEY=
ANTHROPIC_API_KEY=sk-ant-...                          # for Claude connector

# ── Billing (Stripe) ──────────────────────────────────────────────────────────
STRIPE_API_KEY=sk_test_...                            # [WARN_PROD] also checked as STRIPE_SECRET_KEY
STRIPE_SECRET_KEY=sk_test_...                         # alias — only one is needed
STRIPE_WEBHOOK_SECRET=whsec_...                       # [REQUIRED_PROD] from Stripe dashboard webhook config
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BUILDER=price_...
STRIPE_PRICE_OPERATOR=price_...

# ── Communication ─────────────────────────────────────────────────────────────
RESEND_API_KEY=re_...                                 # [WARN_PROD] transactional email (magic links etc.)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Privacy.com (virtual cards) ───────────────────────────────────────────────
PRIVACY_API_KEY=your_privacy_com_api_key

# ── Social Media (Meta / Instagram) ──────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_PAGE_ID=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
META_WEBHOOK_VERIFY_TOKEN=acc_webhook_2026
META_WEBHOOK_APP_SECRET=

# ── Integrations ──────────────────────────────────────────────────────────────
NOTION_API_KEY=ntn_...
AIRTABLE_API_KEY=pat...
AIRTABLE_BASE_ID=app...
CLICKUP_API_KEY=pk_...
CLICKUP_LIST_ID=
COMPOSIO_API_KEY=
GITHUB_TOKEN=ghp_...
SOCIALCLAW_API_KEY=
SOCIALCLAW_BASE_URL=https://getsocialclaw.com
SOCIALCLAW_CLI_PATH=socialclaw
SOCIALCLAW_WORKSPACE_ID=

# ── Observability ─────────────────────────────────────────────────────────────
SENTRY_DSN=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=

# ── Coding Agents ─────────────────────────────────────────────────────────────
OPENHANDS_URL=https://openhands.up.railway.app
OPENHANDS_API_KEY=
OPENHANDS_USER=shayan
AIDER_ENABLED=false
CREWAI_ENABLED=false
ALPHONSO_ENABLED=false
OLLAMA_ENDPOINT=http://localhost:11434

# ── CORS / URLs ───────────────────────────────────────────────────────────────
ACC_PUBLIC_URL=https://acccommand.center
ACC_WEBAPP_URL=https://acccommand.center
ACC_API_BASE_URL=https://acccommand.center
CORS_ALLOWED_ORIGINS=                                 # comma-separated extra origins if needed

# ── Rate Limits ───────────────────────────────────────────────────────────────
MAX_TASKS_PER_USER_PER_HOUR=30
MAX_USERS=100
BRIEFING_TZ=America/Toronto

# ── Browser Automation ────────────────────────────────────────────────────────
BROWSER_SANDBOX=true                                  # set false only after safety review in prod
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
TASKBUS_PROVIDER_ORDER=deepseek,ollama,claude,smart_stub
