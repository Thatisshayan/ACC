{
  "name": "agent-command-center",
  "version": "1.0.0",
  "description": "",
  "main": "acc.js",
  "bin": {
    "acc": "./acc.js"
  },
  "scripts": {
    "test": "node cloud/taskbus/router.test.js && node --test cloud/security/webhookHmac.test.js cloud/taskbus/store.test.js cloud/messages/store.test.js",
    "telegram": "node telegram.js",
    "bridge": "node server.js",
    "cloud:api": "node cloud/server.js",
    "cloud:worker": "node cloud/worker.js",
    "cloud:telegram": "node cloud/telegram/bot.js",
    "start": "node scripts/start.js",
    "server": "node scripts/start.js",
    "mobile:start": "cd mobile && npx expo start",
    "mobile:android": "cd mobile && npx expo run:android",
    "mobile:ios": "cd mobile && npx expo run:ios",
    "mobile:build:android": "cd mobile && npx eas build --platform android --profile preview",
    "mobile:build:ios": "cd mobile && npx eas build --platform ios --profile preview",
    "smoke": "node scripts/smokeTest_sandbox.js",
    "canary:enable": "node scripts/toggleCanary.js enable",
    "canary:disable": "node scripts/toggleCanary.js disable",
    "ui": "cd ui && npm run dev"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.92.0",
    "@aws-sdk/client-s3": "^3.1041.0",
    "@aws-sdk/s3-request-presigner": "^3.1041.0",
    "@supabase/supabase-js": "^2.105.4",
    "axios": "^1.16.0",
    "better-sqlite3": "^12.10.0",
    "body-parser": "^2.2.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "formdata-node": "^6.0.3",
    "node-fetch": "^2.7.0",
    "node-telegram-bot-api": "^0.67.0",
    "playwright": "^1.60.0",
    "stripe": "^22.1.1",
    "uuid": "8.3.2",
    "ws": "^8.20.1"
  },
  "devDependencies": {
    "node-windows": "^1.0.0-beta.8"
  }
}
