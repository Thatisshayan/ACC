{
  "name": "acc-desktop",
  "version": "2.0.0",
  "description": "ACC — Agent Command Center Desktop",
  "author": "Shayan Ezraeil <developer@acccommand.center>",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "fix:electron": "node fix-electron.js",
    "build": "electron-builder --win --publish never",
    "build:dir": "electron-builder --win --dir --publish never",
    "build:win": "electron-builder --win --publish never",
    "build:portable": "electron-builder --win portable --publish never",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.acccommand.center",
    "productName": "ACC",
    "icon": "assets/icon.png",
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "Thatisshayan",
      "repo": "ACC"
    },
    "files": [
      "main.js",
      "preload.js",
      "node_modules/**/*",
      "!node_modules/.cache"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ACC v2",
      "uninstallDisplayName": "ACC v2 Agent Command Center"
    }
  },
  "devDependencies": {
    "electron": "28.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
